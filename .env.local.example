# PropertyHub Environment Configuration
# Copy this file to .env.local and configure your environment variables

# ==============================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# ==============================================

# Payment Configuration (Paystack)
# Get your keys from https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key_here
BACKEND_PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key_here

# API and WebSocket URLs
VITE_API_URL=http://localhost:8080
VITE_WEBSOCKET_URL=ws://localhost:8080
VITE_PAYMENT_WEBHOOK_URL=http://localhost:8080/webhooks/paystack

# Push Notifications (Optional)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ==============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==============================================

# Payment Configuration (Paystack Live)
# VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key_here
# BACKEND_PAYSTACK_SECRET_KEY=sk_live_your_live_secret_key_here

# Production API URLs
# VITE_API_URL=https://api.propertyhub.app
# VITE_WEBSOCKET_URL=wss://api.propertyhub.app
# VITE_PAYMENT_WEBHOOK_URL=https://api.propertyhub.app/webhooks/paystack

# ==============================================
# INSTRUCTIONS
# ==============================================

# 1. Copy this file to .env.local
# 2. Replace the placeholder values with your actual keys
# 3. For development: Use test keys from Paystack
# 4. For production: Use live keys from Paystack
# 5. Never commit your actual .env.local file to version control

# ==============================================
# SECURITY NOTES
# ==============================================

# - Keep your secret keys secure and never expose them in client-side code
# - Use environment variables for all sensitive configuration
# - Regularly rotate your API keys
# - Monitor your Paystack dashboard for suspicious activity
