# PropertyHub local environment variables
# Copy this file to .env.local and replace placeholders with real values.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_EDGE_FUNCTION_NAME=server/make-server-8669f8c6

# App endpoints (Supabase-first; API URL can be derived from the values above)
VITE_API_URL=https://your-project.supabase.co/functions/v1/server/make-server-8669f8c6
VITE_WEBSOCKET_URL=

# Notifications and maps
# Browser push can fetch the public VAPID key from the edge function. Set this only if you want a client fallback.
VITE_VAPID_PUBLIC_KEY=
VITE_MONITORING_ENDPOINT=
# Maps are optional for the fallback map experience.
# Use Google for directions / nearby places and Mapbox for static map previews if you want both.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-public-token
VITE_MAP_DISPLAY_PROVIDER=mapbox

# Payments
VITE_PAYSTACK_PUBLIC_KEY=your-paystack-public-key
VITE_FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
VITE_STRIPE_PUBLIC_KEY=your-stripe-public-key
# Server-only secrets are configured in Supabase Edge Function secrets or Vercel project envs.
# See docs/SERVER_SECRETS_SETUP.md for:
# - BACKEND_PAYSTACK_SECRET_KEY
# - BACKEND_FLUTTERWAVE_SECRET_KEY
# - BACKEND_FLUTTERWAVE_ENCRYPTION_KEY
# - BACKEND_WEBHOOK_SECRET_PAYSTACK
# - BACKEND_WEBHOOK_SECRET_FLUTTERWAVE
# - VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY

# Marketplace behavior
VITE_PAYMENT_COMMISSION_RATE=0.05
VITE_ESCROW_HOLD_DAYS=7
VITE_ESCROW_DISPUTE_WINDOW_HOURS=72

# Development toggles
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
