# PropertyHub Backend Environment Configuration Template
# Copy this file to .env and fill in your actual values
# 🔑 TODO: Replace all placeholder values with your actual API keys

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=8080
HOST=0.0.0.0

# ============================================================================
# SUPABASE DATABASE
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================================================
# JWT/AUTHENTICATION
# ============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-generate-a-random-string
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# ============================================================================
# PAYMENT PROVIDERS
# ============================================================================

# PAYSTACK (https://paystack.com)
# 1. Create account at https://paystack.com
# 2. Go to Settings → API Keys & Webhooks
# 3. Copy keys below
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# FLUTTERWAVE (https://flutterwave.com)
# 1. Create account at https://flutterwave.com
# 2. Go to Settings → API Keys
# 3. Copy test/live keys
FLUTTERWAVE_SECRET_KEY=FLWAVE_SECRET_xxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWAVE_PUBLIC_xxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ============================================================================
# WHATSAPP INTEGRATION (Choose ONE provider)
# ============================================================================

# TWILIO (Easiest for development)
# 1. Sign up at https://twilio.com
# 2. Setup WhatsApp Sandbox at https://console.twilio.com
# 3. Copy credentials below
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# META BUSINESS (WhatsApp Cloud API)
# 1. Create Facebook app at https://developer.facebook.com
# 2. Add WhatsApp product
# 3. Get credentials from App Dashboard
# META_BUSINESS_TOKEN=your-business-token
# META_WHATSAPP_PHONE_ID=your-phone-number-id
# META_WEBHOOK_VERIFY_TOKEN=verify-token-for-webhooks

# MESSAGEBIRD
# 1. Create account at https://messagebird.com
# 2. Go to Settings → API
# MESSAGEBIRD_API_KEY=your-messagebird-api-key

# ============================================================================
# AWS/FILE STORAGE
# ============================================================================
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=propertyhub-files
AWS_S3_URL=https://propertyhub-files.s3.amazonaws.com

# ============================================================================
# OCR SERVICE (For document verification)
# ============================================================================

# GOOGLE VISION API (https://cloud.google.com/vision)
# 1. Create GCP project at https://console.cloud.google.com
# 2. Enable Vision API
# 3. Create service account with Vision permissions
# 4. Get API key
OCR_PROVIDER=google_vision
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# AWS TEXTRACT (Alternative)
# 1. Create AWS account
# 2. Enable Textract service
# AWS_TEXTRACT_ENABLED=false

# TESSERACT.JS (Local - no key needed)
# For local OCR without API keys
# ENABLE_TESSERACT_OCR=true

# ============================================================================
# EMAIL SERVICE (For notifications)
# ============================================================================

# GMAIL / Generic SMTP
# 1. For Gmail: Enable 2FA and create app password
# 2. https://myaccount.google.com/apppasswords
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=PropertyHub

# SENDGRID (Alternative)
# 1. Create account at https://sendgrid.com
# 2. Create API key in Settings → API Keys
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your-sendgrid-key

# ============================================================================
# SMS SERVICE (For phone notifications)
# ============================================================================

# VONAGE/NEXMO (Recommended)
# 1. Create account at https://dashboard.nexmo.com
# 2. Get API credentials from Settings
SMS_PROVIDER=vonage
VONAGE_API_KEY=your-vonage-key
VONAGE_API_SECRET=your-vonage-secret

# TWILIO SMS (Alternative)
# 1. Create account at https://twilio.com
# 2. Get SMS credentials from Console
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxx
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# REDIS (For caching and session storage)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:password@localhost:6379
REDIS_CACHE_ENABLED=false

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=14
LOG_MAX_SIZE=10m

# SENTRY (Error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# DATADOG (Monitoring)
# DATADOG_API_KEY=your-datadog-api-key
# DATADOG_APP_KEY=your-datadog-app-key

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:3000,http://localhost:5173
FRONTEND_DOMAIN=propertyhub.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://propertyhub.com

# ============================================================================
# SOCKET.IO CONFIGURATION
# ============================================================================
SOCKET_IO_CORS_ORIGIN=http://localhost:3000,http://localhost:5173
SOCKET_IO_PATH=/socket.io
SOCKET_IO_TRANSPORTS=websocket,polling

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_KEY_PREFIX=rl

# ============================================================================
# SECURITY
# ============================================================================
ENCRYPTION_KEY=your-encryption-key-32-chars-minimum
WEBHOOK_SECRET=your-webhook-secret-key
API_KEY_SIGNING_SECRET=your-api-key-signing-secret

# ============================================================================
# FEATURE FLAGS (Toggle features on/off)
# ============================================================================
ENABLE_PAYMENTS=true
ENABLE_UTILITIES=true
ENABLE_VERIFICATION=true
ENABLE_ANALYTICS=true
ENABLE_MESSAGING=true
ENABLE_WHATSAPP_INTEGRATION=true
ENABLE_OCR=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false

# ============================================================================
# DEVELOPMENT/TESTING
# ============================================================================
DEBUG=propertyhub:*
TEST_MODE=false
MOCK_PAYMENTS=false
MOCK_WHATSAPP=false
NODE_ENV_ORIGINAL=development
