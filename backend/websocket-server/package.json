{
  "name": "propertyhub-websocket-server",
  "version": "1.0.0",
  "description": "Production WebSocket server for PropertyHub real-time chat system",
  "main": "api-server.js",
  "scripts": {
    "start": "node api-server.js",
    "dev": "node api-server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "docker:build": "docker build -t propertyhub-chat .",
    "docker:run": "docker run -p 8080:8080 --env-file .env propertyhub-chat",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs"
  },
  "keywords": [
    "websocket",
    "real-time",
    "chat",
    "nodejs",
    "socket.io",
    "property",
    "real-estate"
  ],
  "author": "PropertyHub Team",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.2.1",
    "aws-sdk": "^2.1501.0",
    "axios": "^1.15.1",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "redis": "^4.6.10",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.5",
    "socket.io-redis": "^6.1.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/propertyhub-chat-server.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/propertyhub-chat-server/issues"
  },
  "homepage": "https://github.com/yourusername/propertyhub-chat-server#readme"
}
