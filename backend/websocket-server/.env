# Minimal PropertyHub .env for initial run
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# SUPABASE placeholders
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Auth
JWT_SECRET=8f5e1c2d3b4a5e6f7g8h9i0j1k2l3m4n5o6p7q8r9s0t1u2v3w4x5y6z7a8b9c0
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=refresh-secret-xxxxxxxxxx

# Feature Flags
ENABLE_PAYMENTS=true
ENABLE_UTILITIES=true
ENABLE_VERIFICATION=true
ENABLE_ANALYTICS=true
ENABLE_MESSAGING=true
ENABLE_WHATSAPP_INTEGRATION=true
ENABLE_OCR=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true

# Provider Settings (for mocking/testing)
WHATSAPP_PROVIDER=twilio
OCR_PROVIDER=google_vision
EMAIL_PROVIDER=smtp
SMS_PROVIDER=vonage
STORAGE_PROVIDER=local

# Redis (Disable for initial run if not installed)
REDIS_CACHE_ENABLED=false

# Cors
FRONTEND_URL=http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
